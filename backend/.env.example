# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: Gemini (for the RFP frontend) ───────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_key_here

# ── Reddit API (free) ─────────────────────────────────────────────────────────
# Sign up at: https://www.reddit.com/prefs/apps → create script app
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=EASY-Agents/1.0 by your_username

# ── NewsAPI (free tier: 100 req/day) ──────────────────────────────────────────
# Sign up at: https://newsapi.org (free)
NEWS_API_KEY=your_newsapi_key_here

# ── X / Twitter (optional, free basic tier) ───────────────────────────────────
# Apply at: https://developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── The Boss: machine access ───────────────────────────────────────────────────
# Absolute path where The Boss can save files on your Mac
BOSS_WORKSPACE=/Users/your_username/Desktop/EASY-Workspace

# ── Server config ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
